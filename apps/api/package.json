{
  "name": "@bac/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "pnpm build && node --test test/*.test.mjs",
    "typecheck": "pnpm typecheck:local",
    "typecheck:local": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@bac/agent-core": "workspace:*",
    "@bac/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/express": "^5.0.0",
    "typescript": "^5.7.3"
  }
}
